# Database Configuration
# For local development: DATABASE_URL=sqlite:///./moneymate.db
# For Docker: DATABASE_URL=postgresql+psycopg2://moneymate_user:moneymate_password@postgres:5432/moneymate
DATABASE_URL=postgresql+psycopg2://moneymate_user:moneymate_password@postgres:5432/moneymate

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-min-64-characters-long-change-this-in-production

# CORS Configuration
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# Environment
ENVIRONMENT=production

# Optional: Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
